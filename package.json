{
  "name": "voice-stock-studio",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "electron": "electron .",
    "electron:dev": "electron . --inspect",
    "build:mac": "electron-builder --mac --arm64 --x64",
    "build:win": "electron-builder --win --x64",
    "build:all": "electron-builder -mw"
  },
  "build": {
    "appId": "com.fr1ge.studio",
    "productName": "Fr1Ge STUDIO",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "server.js",
      "public/**/*",
      "tools/**/*",
      "package.json",
      "!**/node_modules/**/{test,tests,docs,examples,*.md,*.markdown}"
    ],
    "asar": true,
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "asarUnpack": [
      "server.js",
      "public/**/*",
      "tools/**/*",
      "package.json",
      "node_modules/**/*",
      "node_modules/ffmpeg-static/ffmpeg",
      "node_modules/ffprobe-static/bin/**/*"
    ],
    "mac": {
      "category": "public.app-category.video",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "notarize": false
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "express": "^4.21.2",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "multer": "^2.0.2"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  }
}
